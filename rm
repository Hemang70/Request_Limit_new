# SUBPROCESS HELPER
# ══════════════════════════════════════════════════════════════════════════════

def run(cmd: List[str], timeout: int = 45, retries: int = 2) -> Tuple[int, str, str]:
    last_err = ""
    for attempt in range(retries):
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
            if r.returncode == 0:
                return 0, r.stdout.strip(), r.stderr.strip()
            last_err = r.stderr.strip()
            if any(x in last_err.lower() for x in ("unauthorized", "manifest unknown", "not found")):
                return r.returncode, r.stdout.strip(), last_err
        except subprocess.TimeoutExpired:
            last_err = f"timeout {timeout}s"
        except Exception as e:
            last_err = str(e)
        if attempt < retries - 1:
            time.sleep(2 ** attempt)
    return 1, "", last_err


