class DockerPullCache:
    """Avoid redundant pulls across the 3 runs of the same image."""
    def __init__(self, ttl: int = 600):
        self._cache: Dict[str, float] = {}
        self._lock = Lock()
        self._ttl = ttl

    def is_pulled(self, image: str) -> bool:
        with self._lock:
            ts = self._cache.get(image, 0)
            return (time.time() - ts) < self._ttl

    def mark(self, image: str) -> None:
        with self._lock:
            self._cache[image] = time.time()


class CgroupPathCache:
    """Cache cgroup filesystem paths per container to avoid repeated stat calls."""
    def __init__(self):
        self._cpu:    Dict[str, Optional[str]] = {}
        self._mem:    Dict[str, Optional[str]] = {}
        self._lock    = Lock()

    def _find(self, container_id: str, metric: str) -> Optional[str]:
        """Find cgroup path for a given metric file."""
        if metric == "cpu":
            candidates = [
                f"/sys/fs/cgroup/system.slice/docker-{container_id}.scope/cpu.stat",
                f"/sys/fs/cgroup/docker/{container_id}/cpu.stat",
                f"/sys/fs/cgroup/cpu/docker/{container_id}/cpuacct.usage",
            ]
        else:  # memory
            candidates = [
                # cgroup v2 (Amazon Linux 2023, Ubuntu 22.04)
                f"/sys/fs/cgroup/system.slice/docker-{container_id}.scope/memory.current",
                f"/sys/fs/cgroup/docker/{container_id}/memory.current",
                # cgroup v1 fallback
                f"/sys/fs/cgroup/memory/docker/{container_id}/memory.usage_in_bytes",
            ]
        for p in candidates:
            if os.path.exists(p):
                return p
        return None

    def get_cpu_path(self, cid: str) -> Optional[str]:
        with self._lock:
            if cid not in self._cpu:
                self._cpu[cid] = self._find(cid, "cpu")
            return self._cpu[cid]

    def get_mem_path(self, cid: str) -> Optional[str]:
        with self._lock:
            if cid not in self._mem:
                self._mem[cid] = self._find(cid, "memory")
            return self._mem[cid]


