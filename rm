class AdaptiveWorkerPool:
    """Reduce workers if host CPU > 85%, increase if < 55%."""
    def __init__(self, initial: int = INITIAL_WORKERS):
        self._n    = initial
        self._lock = Lock()
        self._last = time.time()

    def current(self) -> int:
        if not HAVE_PSUTIL:
            return self._n
        with self._lock:
            if time.time() - self._last < 30:
                return self._n
            cpu = psutil.cpu_percent(interval=0.1)
            if cpu > TARGET_CPU_USAGE + 10 and self._n > MIN_WORKERS:
                self._n -= 1
                print(f"  [adaptive] host CPU {cpu:.0f}% → workers ↓ {self._n}")
            elif cpu < TARGET_CPU_USAGE - 20 and self._n < MAX_WORKERS:
                self._n += 1
                print(f"  [adaptive] host CPU {cpu:.0f}% → workers ↑ {self._n}")
            self._last = time.time()
            return self._n


